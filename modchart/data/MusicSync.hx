package modchart.data;

typedef MusicSync = {
	// Music position in ms.
	msPosition:Float,
	// Music position in Beats.
	beatPosition:Float,
	// Music position in Steps.
	stepPosition:Float,

	// Duration of a step in ms.
	msStepDuration:Float,
	// Duration of a beat in ms.
	msBeatDuration:Float,
	// Duration of a measure in ms.
	msMeasureDuration:Float,
}
